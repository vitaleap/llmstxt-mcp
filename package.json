{
  "name": "mcp-server-template",
  "version": "0.1.0",
  "author": "",
  "license": "MIT",
  "description": "Mcp Server Template",
  "type": "module",
  "scripts": {
    "dev": "run-p watch start:sse start:streamableHttp inspector",
    "build": "tsdown && shx chmod +x dist/stdio.js",
    "watch": "tsdown --watch",
    "inspector": "npx -y @modelcontextprotocol/inspector",
    "start:stdio": "tsx watch src/stdio.ts",
    "start:sse": "tsx watch src/sse.ts",
    "start:streamableHttp": "tsx watch src/streamableHttp.ts",
    "check": "run-p check:*",
    "check:format": "prettier --check src/",
    "check:tsc": "tsc --noEmit",
    "lint": "run-p lint:*",
    "lint:format": "prettier --write src/",
    "release": "run-p check release:*",
    "release:version": "commit-and-tag-version"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.28.0",
    "express": "~5.2.1",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/express": "~5.0.6",
    "@types/node": "^24.10.0",
    "@vercel/nft": "~1.3.2",
    "commit-and-tag-version": "^12.7.1",
    "fs-extra": "~11.3.0",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "shx": "~0.4.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2"
  },
  "bin": {
    "mcp-server-template": "dist/stdio.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10"
  },
  "exports": {
    "./sse": "./dist/sse.js",
    "./stdio": "./dist/stdio.js",
    "./streamableHttp": "./dist/streamableHttp.js",
    "./package.json": "./package.json"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit \"$1\"",
    "pre-commit": "npx lint-staged"
  }
}
